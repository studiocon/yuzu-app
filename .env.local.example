# ---- Required ----
# ElevenLabs Scribe v2（STT）。https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Anthropic Claude（レポート生成・感情分析）。https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Supabase（DB + Auth）。プロジェクト設定 → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サーバー専用。RLS をバイパスする。**絶対に NEXT_PUBLIC_ を付けない**
SUPABASE_SERVICE_ROLE_KEY=

# ---- Optional ----
# 問い合わせ（/api/inquiries）受信時に通知する Slack Incoming Webhook URL。
# 未設定の場合は通知をスキップする（保存は成功する）。
SLACK_WEBHOOK_URL=

# Sentry（#113）。https://sentry.io/settings/projects/yuzu-app/keys/
# 未設定の場合は init を skip して noop。
# DSN はクライアント側も同じ値を使うため NEXT_PUBLIC_ を付与（DSN は公開しても OK）。
NEXT_PUBLIC_SENTRY_DSN=

# Source map upload に必要（Vercel ビルドでのみ設定。ローカルでは不要）。
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
